{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Bowie",
	"scopeName": "source.bow",
	"fileTypes": ["bow"],
	"patterns": [
		{ "include": "#comment" },
		{ "include": "#string" },
		{ "include": "#number" },
		{ "include": "#exception-keyword" },
		{ "include": "#keyword" },
		{ "include": "#constant" },
		{ "include": "#builtin" },
		{ "include": "#function-def" },
		{ "include": "#function-call" },
		{ "include": "#operator" },
		{ "include": "#punctuation" },
		{ "include": "#variable" }
	],
	"repository": {
		"comment": {
			"name": "comment.line.hash.bowie",
			"match": "#.*$"
		},

		"string": {
			"name": "string.quoted.double.bowie",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.bowie",
					"match": "\\\\[\\\\\"nrt]"
				}
			]
		},

		"number": {
			"patterns": [
				{
					"name": "constant.numeric.float.bowie",
					"match": "\\b[0-9]+\\.[0-9]+\\b"
				},
				{
					"name": "constant.numeric.integer.bowie",
					"match": "\\b[0-9]+\\b"
				}
			]
		},

		"exception-keyword": {
			"name": "keyword.control.exception.bowie",
			"match": "\\b(try|catch|finally|throw)\\b"
		},

		"keyword": {
			"patterns": [
				{
					"name": "keyword.control.bowie",
					"match": "\\b(if|else|while|for|in|return|break|continue|try|catch|finally|throw|await)\\b"
				},
				{
					"name": "keyword.other.bowie",
					"match": "\\b(let|const|fn|import|export|as|use|async)\\b"
				}
			]
		},

		"constant": {
			"patterns": [
				{
					"name": "constant.language.boolean.bowie",
					"match": "\\b(true|false)\\b"
				},
				{
					"name": "constant.language.null.bowie",
					"match": "\\bnull\\b"
				}
			]
		},

		"builtin": {
			"name": "support.function.builtin.bowie",
			"match": "\\b(print|println|printf|sprintf|vsprintf|eprint|input|str|int|float|bool|type|error_type|is_error_type|len|push|pop|keys|values|range|slice|index_of|lookup|split|join|trim|upper|lower|contains|replace|starts_with|ends_with|floor|ceil|abs|sqrt|pow|max|min|env|env_or|read_file|write_file|append_file|json_encode|json_decode|fetch|create_server|route|serve|pg_connect|pg_close|pg_query|exit|assert|is_null)\\b(?=\\s*\\()"
		},

		"function-def": {
			"patterns": [
				{
					"comment": "named function: fn foo(",
					"match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": { "name": "keyword.other.bowie" },
						"2": { "name": "entity.name.function.bowie" }
					}
				},
				{
					"comment": "named async function: async fn foo(",
					"match": "\\b(async)\\s+(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": { "name": "keyword.other.bowie" },
						"2": { "name": "keyword.other.bowie" },
						"3": { "name": "entity.name.function.bowie" }
					}
				}
			]
		},

		"function-call": {
			"match": "\\b(?!(?:if|else|while|for|in|return|break|continue|try|catch|finally|throw|await|let|const|fn|import|export|as|use|async|true|false|null)\\b)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
			"captures": {
				"1": { "name": "entity.name.function.call.bowie" }
			}
		},

		"operator": {
			"patterns": [
				{
					"name": "keyword.operator.comparison.bowie",
					"match": "==|!=|<=|>=|<|>"
				},
				{
					"name": "keyword.operator.logical.bowie",
					"match": "&&|\\|\\||!"
				},
				{
					"name": "keyword.operator.assignment.bowie",
					"match": "(?<![=!<>])=(?!=)"
				},
				{
					"name": "keyword.operator.arithmetic.bowie",
					"match": "\\+\\+|--|\\+|-|\\*|/|%"
				},
				{
					"name": "keyword.operator.spread.bowie",
					"match": "\\.\\.\\."
				}
			]
		},

		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.definition.block.bowie",
					"match": "[{}]"
				},
				{
					"name": "punctuation.definition.bracket.bowie",
					"match": "[\\[\\]]"
				},
				{
					"name": "punctuation.definition.paren.bowie",
					"match": "[()]"
				},
				{
					"name": "punctuation.separator.bowie",
					"match": "[,:;.]"
				}
			]
		},

		"variable": {
			"name": "variable.other.bowie",
			"match": "\\b(?!(?:if|else|while|for|in|return|break|continue|try|catch|finally|throw|await|let|const|fn|import|export|as|use|async|true|false|null)\\b)[a-zA-Z_][a-zA-Z0-9_]*\\b"
		}
	}
}
