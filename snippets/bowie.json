{
	"Let variable": {
		"prefix": "let",
		"body": ["let ${1:name} = $2"],
		"description": "Declare a variable"
	},
	"Const variable": {
		"prefix": "const",
		"body": ["const ${1:name} = $2"],
		"description": "Declare an immutable variable"
	},
	"Function definition": {
		"prefix": "fn",
		"body": ["fn ${1:name}(${2:args}) {", "\t$0", "}"],
		"description": "Define a named function"
	},
	"Anonymous function": {
		"prefix": "afn",
		"body": ["fn(${1:args}) { $0 }"],
		"description": "Anonymous function expression"
	},
	"If statement": {
		"prefix": "if",
		"body": ["if ${1:condition} {", "\t$0", "}"],
		"description": "If statement"
	},
	"If-else statement": {
		"prefix": "ife",
		"body": ["if ${1:condition} {", "\t$2", "} else {", "\t$0", "}"],
		"description": "If-else statement"
	},
	"While loop": {
		"prefix": "while",
		"body": ["while ${1:condition} {", "\t$0", "}"],
		"description": "While loop"
	},
	"For-in loop": {
		"prefix": "for",
		"body": ["for ${1:item} in ${2:collection} {", "\t$0", "}"],
		"description": "For-in loop"
	},
	"Async function definition": {
		"prefix": "asyncfn",
		"body": ["async fn ${1:name}(${2:args}) {", "\t$0", "}"],
		"description": "Define an async function"
	},
	"Await expression": {
		"prefix": "await",
		"body": ["await ${1:promise}"],
		"description": "Await an async result"
	},
	"Try-catch": {
		"prefix": "try",
		"body": [
			"try {",
			"\t$1",
			"} catch (${2:err}) {",
			"\t$0",
			"}"
		],
		"description": "Try-catch block"
	},
	"Try-catch-finally": {
		"prefix": "tryf",
		"body": [
			"try {",
			"\t$1",
			"} catch (${2:err}) {",
			"\t$3",
			"} finally {",
			"\t$0",
			"}"
		],
		"description": "Try-catch-finally block"
	},
	"Throw error": {
		"prefix": "throw",
		"body": ["throw ${1:error}"],
		"description": "Throw an error"
	},
	"Fetch request": {
		"prefix": "fetch",
		"body": [
			"let ${1:resp} = fetch(\"${2:https://example.com}\", {",
			"\t\"method\": \"${3:GET}\",",
			"\t\"headers\": {\"Content-Type\": \"application/json\"},",
			"\t\"body\": ${4:json_encode({})}",
			"})"
		],
		"description": "HTTP fetch call with options"
	},
	"Break": {
		"prefix": "break",
		"body": ["break"],
		"description": "Break from loop"
	},
	"Continue": {
		"prefix": "continue",
		"body": ["continue"],
		"description": "Continue next loop iteration"
	},
	"HTTP server": {
		"prefix": "server",
		"body": [
			"let ${1:server} = create_server(${2:8080})",
			"",
			"route(${1:server}, \"GET\", \"/${3:path}\", fn(req) {",
			"\treturn {",
			"\t\t\"status\": 200,",
			"\t\t\"body\": json_encode({$4}),",
			"\t\t\"headers\": {\"Content-Type\": \"application/json\"}",
			"\t}",
			"})",
			"",
			"serve(${1:server})"
		],
		"description": "HTTP server boilerplate"
	},
	"Route handler": {
		"prefix": "route",
		"body": [
			"route(${1:server}, \"${2|GET,POST,PUT,DELETE|}\", \"/${3:path}\", fn(req) {",
			"\treturn {",
			"\t\t\"status\": ${4:200},",
			"\t\t\"body\": $5,",
			"\t\t\"headers\": {\"Content-Type\": \"application/json\"}",
			"\t}",
			"})"
		],
		"description": "HTTP route handler"
	},
	"JSON response": {
		"prefix": "jres",
		"body": [
			"{",
			"\t\"status\": ${1:200},",
			"\t\"body\": json_encode($2),",
			"\t\"headers\": {\"Content-Type\": \"application/json\"}",
			"}"
		],
		"description": "JSON HTTP response hash"
	},
	"JSON encode": {
		"prefix": "je",
		"body": ["json_encode($1)"],
		"description": "Encode value to JSON string"
	},
	"JSON decode": {
		"prefix": "jd",
		"body": ["json_decode($1)"],
		"description": "Decode JSON string to value"
	},
	"println": {
		"prefix": "pl",
		"body": ["println($1)"],
		"description": "Print with newline"
	},
	"Read environment variable": {
		"prefix": "env",
		"body": ["let ${1:val} = env_or(\"${2:VAR}\", \"${3:default}\")"],
		"description": "Read env variable with default"
	},
	"Read file": {
		"prefix": "rf",
		"body": ["let ${1:content} = read_file(\"${2:path}\")"],
		"description": "Read file contents"
	},
	"Write file": {
		"prefix": "wf",
		"body": ["write_file(\"${1:path}\", ${2:content})"],
		"description": "Write content to file"
	},
	"Hash map": {
		"prefix": "hash",
		"body": ["let ${1:map} = {", "\t\"${2:key}\": ${3:value}", "}"],
		"description": "Hash map literal"
	},
	"Array": {
		"prefix": "arr",
		"body": ["let ${1:items} = [$2]"],
		"description": "Array literal"
	},
	"Assert": {
		"prefix": "assert",
		"body": ["assert($1, \"${2:assertion failed}\")"],
		"description": "Assert expression is truthy"
	},

	"Import module": {
		"prefix": "imp",
		"body": ["import \"${1:path}\""],
		"description": "Import a module"
	},
	"Import with alias": {
		"prefix": "impa",
		"body": ["import \"${1:path}\" as ${2:name}"],
		"description": "Import module with alias"
	},
	"Import named": {
		"prefix": "impu",
		"body": ["import \"${1:path}\" use ${2:name}"],
		"description": "Import named exports from module"
	},
	"Export declaration": {
		"prefix": "exp",
		"body": ["export ${1:fn ${2:name}(${3:args}) {\n\t$0\n}}"],
		"description": "Export a declaration"
	},

	"PostgreSQL connect": {
		"prefix": "pgconn",
		"body": ["let ${1:conn} = pg_connect(\"${2:host=localhost dbname=mydb user=postgres}\")"],
		"description": "Connect to PostgreSQL"
	},
	"PostgreSQL query": {
		"prefix": "pgq",
		"body": ["let ${1:rows} = pg_query(${2:conn}, \"${3:SELECT * FROM ${4:table}}\")"],
		"description": "Execute a PostgreSQL query"
	},
	"PostgreSQL boilerplate": {
		"prefix": "pg",
		"body": [
			"let ${1:conn} = pg_connect(\"${2:host=localhost dbname=mydb user=postgres}\")",
			"",
			"let ${3:rows} = pg_query(${1:conn}, \"${4:SELECT * FROM ${5:table}}\")",
			"",
			"pg_close(${1:conn})"
		],
		"description": "PostgreSQL connect, query, close"
	},

	"sprintf": {
		"prefix": "sf",
		"body": ["let ${1:s} = sprintf(\"${2:%s}\", $3)"],
		"description": "Format string with sprintf"
	},
	"eprint": {
		"prefix": "ep",
		"body": ["eprint(${1:value})"],
		"description": "Print to stderr"
	},
	"Append file": {
		"prefix": "af",
		"body": ["append_file(\"${1:path}\", ${2:content})"],
		"description": "Append content to file"
	},
	"Range loop": {
		"prefix": "forr",
		"body": ["for ${1:i} in range(${2:end}) {", "\t$0", "}"],
		"description": "For loop over a range"
	},
	"Error type check": {
		"prefix": "errtype",
		"body": [
			"if is_error_type(${1:err}, \"${2:type}\") {",
			"\t$0",
			"}"
		],
		"description": "Check error type"
	}
}
